<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_padel_booking" model="ir.sequence">
        <field name="name">Reserva de padel</field>
        <field name="code">padel.booking</field>
        <field name="prefix">PADEL/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="product_padel_booking" model="product.product">
        <field name="name">Reserva pista de padel</field>
        <field name="type">service</field>
        <field name="sale_ok">True</field>
        <field name="purchase_ok">False</field>
        <field name="list_price">0.0</field>
    </record>
</odoo>
