<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_padel_court_list" model="ir.ui.view">
        <field name="name">padel.court.list</field>
        <field name="model">padel.court</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="court_type"/>
                <field name="default_price"/>
                <field name="allow_website_booking"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_padel_court_form" model="ir.ui.view">
        <field name="name">padel.court.form</field>
        <field name="model">padel.court</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bookings" type="object" class="oe_stat_button" icon="fa-calendar">
                            <field name="booking_count" widget="statinfo" string="Reservas"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="court_type"/>
                            <field name="default_price"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="allow_website_booking"/>
                            <field name="color"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_padel_court" model="ir.actions.act_window">
        <field name="name">Pistas</field>
        <field name="res_model">padel.court</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
