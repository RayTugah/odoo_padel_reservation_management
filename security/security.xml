<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 19: res.groups no usa category_id. -->
    <record id="group_padel_user" model="res.groups">
        <field name="name">Usuario de padel</field>
    </record>

    <record id="group_padel_manager" model="res.groups">
        <field name="name">Administrador de padel</field>
        <field name="implied_ids" eval="[(4, ref('odoo_padel_reservation_management.group_padel_user'))]"/>
    </record>

    <!-- Los usuarios internos pueden ver y utilizar la app base. -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('odoo_padel_reservation_management.group_padel_user'))]"/>
    </record>

    <!-- Los administradores de ajustes tambien reciben la configuracion de padel. -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('odoo_padel_reservation_management.group_padel_manager'))]"/>
    </record>
</odoo>
